# Copy selected values into .env for local development, or into
# ~/.config/3dprintpilot/3dprintpilot.env for the systemd user service.

PRINTPILOT_APP_NAME=3dPrintPilot
PRINTPILOT_APP_VERSION=0.1.0
PRINTPILOT_ENVIRONMENT=development
PRINTPILOT_LOG_LEVEL=INFO

PRINTPILOT_DATABASE_URL=postgresql+psycopg://3dprintpilot:3dprintpilot@localhost:5432/3dprintpilot

# The default frontend dev server runs on 5173. If that port is occupied on a
# local workstation, set this for the user service and reinstall/restart it.
PRINTPILOT_FRONTEND_PORT=5173
PRINTPILOT_BACKEND_PORT=8001

PRINTPILOT_OLLAMA_BASE_URL=http://localhost:11434/api
PRINTPILOT_LOCAL_LLM_DEFAULT_MODEL=qwen3-coder:30b
PRINTPILOT_OPENAI_FALLBACK_ENABLED=false

# Prefer an environment variable or OS-protected file for production-like use.
# PRINTPILOT_FIELD_ENCRYPTION_KEY=
# PRINTPILOT_FIELD_ENCRYPTION_KEY_FILE=.secrets/field-encryption.key
